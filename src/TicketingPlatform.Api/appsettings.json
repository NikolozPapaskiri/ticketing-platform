{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5433;Database=ticketing;Username=ticketing;Password=ticketing",
    "Redis": "localhost:6379"
  },
  "PaymentProvider": {
    "BaseUrl": "http://localhost:5000/dev-payment/"
  },
  "Reservation": {
    "Strategy": "OptimisticConcurrency"
  },
  "Holds": {
    "TtlSeconds": 600,
    "ExpiryScanSeconds": 15
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "ticketing",
    "Password": "ticketing",
    "Exchange": "ticketing-events",
    "DeadLetterExchange": "ticketing-dlx"
  },
  "Jwt": {
    "Issuer": "ticketing-platform",
    "Audience": "ticketing-api",
    "AccessTokenMinutes": 15,
    "SigningKey": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*"
}
