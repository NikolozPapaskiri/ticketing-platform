{
  "uid": "ticketing-checkout",
  "title": "Ticketing — Checkout & Payments",
  "tags": ["ticketing"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "Order outcomes (per sec)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(ticketing_orders_confirmed[5m]))", "legendFormat": "confirmed", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "sum(rate(ticketing_orders_payment_declined[5m]))", "legendFormat": "declined", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "C", "expr": "sum(rate(ticketing_orders_payment_unavailable[5m]))", "legendFormat": "unavailable", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "D", "expr": "sum(rate(ticketing_orders_refunded[5m]))", "legendFormat": "refunded", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 2, "type": "stat", "title": "Payments awaiting reconciliation",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "max(ticketing_payments_reconciliation_backlog)", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "id": 3, "type": "stat", "title": "Refunds pending reconciliation",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "max(ticketing_refunds_reconciliation_backlog)", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "id": 4, "type": "timeseries", "title": "Holds: attempts vs conflicts (per sec)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(ticketing_holds_attempts[5m]))", "legendFormat": "attempts", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "sum(rate(ticketing_holds_conflicts[5m]))", "legendFormat": "conflicts", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 5, "type": "timeseries", "title": "HTTP request rate (per sec, by status)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "ASP.NET Core instrumentation. Metric name may vary by version - confirm against the live stack.",
      "targets": [{ "refId": "A", "expr": "sum by (http_response_status_code) (rate(http_server_request_duration_count[5m]))", "legendFormat": "{{http_response_status_code}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "id": 6, "type": "timeseries", "title": "HTTP latency p95 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_request_duration_bucket[5m])))", "legendFormat": "p95", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "id": 7, "type": "timeseries", "title": "HTTP 5xx rate (per sec)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "sum(rate(http_server_request_duration_count{http_response_status_code=~\"5..\"}[5m]))", "legendFormat": "5xx/s", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    }
  ]
}
